# Example environment configuration for deluxe E2E test
# Copy this file to .env and fill in your actual values

# Required: Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-...

# Required: Your GCP project ID
GOLDFISH_GCE_PROJECT=my-gcp-project-123

# Required: Your GCS bucket (must already exist)
GOLDFISH_GCS_BUCKET=gs://my-goldfish-test-bucket

# Optional: Path to GCP service account key (if not using application default credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Optional: Dry-run mode (1 = skip GCE launches, just test MCP)
# GOLDFISH_DELUXE_DRY_RUN=0
