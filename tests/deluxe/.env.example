# NOTE: This file is for reference only
#
# The deluxe E2E test uses your existing .env file from the repository root.
# This is just an example of what variables are required.
#
# To configure the test, edit your main .env file:
#   cd ../../
#   vim .env

# Required: Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Required: Your GCP project ID
GOLDFISH_GCE_PROJECT=my-gcp-project-123

# Required: Your GCS bucket (must already exist)
GOLDFISH_GCS_BUCKET=gs://my-goldfish-bucket

# Optional: Path to GCP service account key (if not using application default credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
